# Server Configuration
PORT=8080

# Primary Database (Neon - Production / Postgres - Local)
# For local: postgres://admin:password@postgres:5432/mmochill?sslmode=disable
DATABASE_URL=postgres://admin:password@localhost:5432/mmochill?sslmode=disable

# Redis (Upstash - Production / Redis - Local)
# For local: localhost:6379
REDIS_URL=localhost:6379
REDIS_PASSWORD=

# RabbitMQ (CloudAMQP - Production / RabbitMQ - Local)
# For local: amqp://guest:guest@localhost:5672/
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Auth
JWT_SECRET=your-secret-key
